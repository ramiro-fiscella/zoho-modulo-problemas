    {
      "parameters": {
        "jsCode": "// Toma la respuesta cruda del nodo HTTP Request y arma { statusCode, body }\n// para que el nodo Respond to Webhook lo devuelva tal cual al portal.\n\nconst item = $input.first();\nconst data = item.json;\n\n// Caso 1: fallo de red/timeout/DNS -> el nodo HTTP quedó con continueOnFail\n// y devuelve el error acá en vez de tirar la ejecución entera.\nif (data.error) {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'No se pudo contactar a Zoho: ' + (data.error.message || JSON.stringify(data.error))\n      }\n    }\n  }];\n}\n\n// Caso 2: la llamada HTTP entró pero Zoho rechazó la ejecución de la función\n// (auth_type/zapikey inválido, función no encontrada, etc.) -> code != \"success\"\nif (data.code && data.code !== 'success') {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'Zoho no pudo ejecutar la función: ' + (data.message || data.code),\n        detalleZoho: data\n      }\n    }\n  }];\n}\n\n// Caso 3: todo OK a nivel HTTP/ejecución -> el resultado real de\n// problemas_create_standalone viene como STRING JSON en details.output\nlet salida;\ntry {\n  const outputStr = data.details && data.details.output;\n  salida = JSON.parse(outputStr);\n} catch (e) {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'No se pudo parsear la respuesta de la función: ' + e.message,\n        rawOutput: data.details ? data.details.output : data\n      }\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    statusCode: salida.ok ? 200 : 400,\n    body: salida\n  }\n}];\n"
      },
