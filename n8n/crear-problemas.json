      "parameters": {
        "jsCode": "// Mismo parseo que en crear-problemas: toma la respuesta cruda del nodo\n// HTTP Request y arma { statusCode, body } para Respond to Webhook.\n\nconst item = $input.first();\nconst data = item.json;\n\n// Caso 1: fallo de red/timeout/DNS\nif (data.error) {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'No se pudo contactar a Zoho: ' + (data.error.message || JSON.stringify(data.error))\n      }\n    }\n  }];\n}\n\n// Caso 2: Zoho rechazó la ejecución de la función (auth_type/zapikey inválido, etc.)\nif (data.code && data.code !== 'success') {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'Zoho no pudo ejecutar la función: ' + (data.message || data.code),\n        detalleZoho: data\n      }\n    }\n  }];\n}\n\n// Caso 3: todo OK -> el resultado real de problemas_buscar_legajo viene como\n// STRING JSON en details.output\nlet salida;\ntry {\n  const outputStr = data.details && data.details.output;\n  salida = JSON.parse(outputStr);\n} catch (e) {\n  return [{\n    json: {\n      statusCode: 502,\n      body: {\n        ok: false,\n        error: 'No se pudo parsear la respuesta de la función: ' + e.message,\n        rawOutput: data.details ? data.details.output : data\n      }\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    statusCode: salida.ok ? 200 : 400,\n    body: salida\n  }\n}];\n"
      },
